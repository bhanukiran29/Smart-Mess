<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <com.journeyapps.barcodescanner.DecoratedBarcodeView
        android:id="@+id/zxing_barcode_scanner"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:zxing_use_texture_view="true" />

    <!-- Center Cutout Reference -->
    <View
        android:id="@+id/scanWindow"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_marginBottom="64dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 60% Black Scrims -->
    <View
        android:id="@+id/scrimTop"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#99000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/scanWindow" />

    <View
        android:id="@+id/scrimBottom"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#99000000"
        app:layout_constraintTop_toBottomOf="@id/scanWindow"
        app:layout_constraintBottom_toBottomOf="parent" />

    <View
        android:id="@+id/scrimLeft"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#99000000"
        app:layout_constraintTop_toTopOf="@id/scanWindow"
        app:layout_constraintBottom_toBottomOf="@id/scanWindow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/scanWindow" />

    <View
        android:id="@+id/scrimRight"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#99000000"
        app:layout_constraintTop_toTopOf="@id/scanWindow"
        app:layout_constraintBottom_toBottomOf="@id/scanWindow"
        app:layout_constraintStart_toEndOf="@id/scanWindow"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top Area Content -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:padding="12dp"
        android:src="@android:drawable/ic_menu_revert"
        app:tint="#FFFFFF"
        android:layout_marginTop="32dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvScanTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Scan QR Code"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvScanSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Point your camera at the QR code at the mess entrance"
        android:textColor="#CBD5E1"
        android:textSize="12sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvScanTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scan Line Wrapper to constrain sweep -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clBrackets"
        android:layout_width="240dp"
        android:layout_height="240dp"
        app:layout_constraintTop_toTopOf="@id/scanWindow"
        app:layout_constraintStart_toStartOf="@id/scanWindow">

        <!-- Top Left Bracket -->
        <View android:id="@+id/tl_h" android:layout_width="24dp" android:layout_height="3dp" android:background="#FFFFFF" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
        <View android:id="@+id/tl_v" android:layout_width="3dp" android:layout_height="24dp" android:background="#FFFFFF" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>

        <!-- Top Right Bracket -->
        <View android:id="@+id/tr_h" android:layout_width="24dp" android:layout_height="3dp" android:background="#FFFFFF" app:layout_constraintTop_toTopOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
        <View android:id="@+id/tr_v" android:layout_width="3dp" android:layout_height="24dp" android:background="#FFFFFF" app:layout_constraintTop_toTopOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Bottom Left Bracket -->
        <View android:id="@+id/bl_h" android:layout_width="24dp" android:layout_height="3dp" android:background="#FFFFFF" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent"/>
        <View android:id="@+id/bl_v" android:layout_width="3dp" android:layout_height="24dp" android:background="#FFFFFF" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent"/>

        <!-- Bottom Right Bracket -->
        <View android:id="@+id/br_h" android:layout_width="24dp" android:layout_height="3dp" android:background="#FFFFFF" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
        <View android:id="@+id/br_v" android:layout_width="3dp" android:layout_height="24dp" android:background="#FFFFFF" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Animated Sweeping Scan Line -->
        <View
            android:id="@+id/viewScanLine"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#FFFFFF"
            android:translationY="-2dp"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- SUCCESS / ERROR FLASH OVERLAY -->
    <View
        android:id="@+id/viewFlash"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#00A34F"
        android:alpha="0"
        android:elevation="10dp"/>

    <!-- Bottom Area -->
    <TextView
        android:id="@+id/tvScanningFor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Scanning for: Lunch"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/scanWindow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnFlashlight"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="#26FFFFFF"
        app:cardElevation="0dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvScanningFor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔦"
            android:textSize="20sp"
            android:layout_gravity="center" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Bottom Sheet Result Drawer (Hidden Initially) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="32dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        android:translationY="400dp"
        android:alpha="0">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <!-- Checkmark or X Icon -->
            <TextView
                android:id="@+id/tvResultIcon"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:text="✅"
                android:textSize="48sp"
                android:gravity="center"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvResultTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Meal Confirmed!"
                android:textColor="#0F172A"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvResultSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lunch | Today"
                android:textColor="#64748B"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvResultMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enjoy your lunch!"
                android:textColor="#1E3A8A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResultDismiss"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Dismiss"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#1E3A8A"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
