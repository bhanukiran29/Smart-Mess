<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🍽 My Meal History"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Last 7 days of meals eaten"
        android:textSize="13sp"
        android:textColor="#888"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:id="@+id/tvEmptyHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No meal scans found in the last 7 days."
        android:textSize="15sp"
        android:textColor="#999"
        android:gravity="center"
        android:layout_marginTop="80dp"
        android:visibility="gone"/>

    <ListView
        android:id="@+id/lvMealHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:dividerHeight="8dp"/>

    <Button
        android:id="@+id/btnHistoryBack"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="← Back"
        android:layout_marginTop="16dp"
        style="?attr/materialButtonOutlinedStyle"/>
</LinearLayout>
