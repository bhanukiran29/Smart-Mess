<?xml version="1.0" encoding="utf-8"?>
<!--
    item_timeline_entry.xml
    Row layout for a single entry in the History (unified timeline) tab.
    Shows: Date, Meal Type, Status badge, and optional scan time sub-line.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E2E8F0"
    app:cardBackgroundColor="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- Dynamic colour bar on the left -->
        <View
            android:id="@+id/viewTimelineBar"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="#22C55E"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Meal icon -->
        <TextView
            android:id="@+id/tvTimelineMealIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:textSize="22sp"
            android:text="🍳"
            app:layout_constraintStart_toEndOf="@id/viewTimelineBar"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="10dp" />

        <!-- Date (bold) -->
        <TextView
            android:id="@+id/tvTimelineDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Jun 02, 2026"
            android:textColor="#0F172A"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/tvTimelineMealIcon"
            app:layout_constraintEnd_toStartOf="@id/tvTimelineStatusBadge"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="2dp" />

        <!-- Meal type -->
        <TextView
            android:id="@+id/tvTimelineMealType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Breakfast"
            android:textColor="#64748B"
            android:textSize="12sp"
            app:layout_constraintStart_toEndOf="@id/tvTimelineMealIcon"
            app:layout_constraintEnd_toStartOf="@id/tvTimelineStatusBadge"
            app:layout_constraintTop_toBottomOf="@id/tvTimelineDate"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="2dp" />

        <!-- Sub-line: scan time or time slot (optional) -->
        <TextView
            android:id="@+id/tvTimelineSubLine"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Scanned at 8:05 AM"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:visibility="gone"
            app:layout_constraintStart_toEndOf="@id/tvTimelineMealIcon"
            app:layout_constraintEnd_toStartOf="@id/tvTimelineStatusBadge"
            app:layout_constraintTop_toBottomOf="@id/tvTimelineMealType"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="2dp" />

        <!-- Status badge -->
        <TextView
            android:id="@+id/tvTimelineStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Attended"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_badge_green"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
