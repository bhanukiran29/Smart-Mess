<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="16dp">

    <!-- Optional Date Header -->
    <TextView
        android:id="@+id/tvDateHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TODAY"
        android:textColor="#94A3B8"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:layout_marginStart="4dp"
        android:visibility="gone"/>

    <!-- Meal Card Row -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E2E8F0"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Dynamic Color Strip -->
            <View
                android:id="@+id/viewColorStrip"
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="#16A34A" />

            <!-- Meal Icon Square -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvMealIcon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#DCFCE7"
                android:layout_marginStart="12dp"
                android:layout_marginVertical="12dp">
                <TextView
                    android:id="@+id/tvMealIconText"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="☀️"
                    android:textSize="16sp"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- Text Content -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                
                <TextView
                    android:id="@+id/tvMealName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Breakfast"
                    android:textColor="#0F172A"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                    
                <TextView
                    android:id="@+id/tvMealTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="08:00 AM • Walk-in"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Status Badge -->
            <TextView
                android:id="@+id/tvBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_history_badge"
                android:text="₹50 charged"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginEnd="16dp"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
