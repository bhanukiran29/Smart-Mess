<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E2E8F0"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Avatar circle with initials -->
        <TextView
            android:id="@+id/tvAvatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/avatar_circle_blue" />

        <!-- Name / email / hostel -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="2dp">

                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="User Name"
                    android:textColor="#0F172A"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <!-- Role badge pill -->
                <TextView
                    android:id="@+id/tvRoleBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Student"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:background="@drawable/badge_student" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvUserEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="user@example.com"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="3dp" />

            <TextView
                android:id="@+id/tvUserHostel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Block A"
                android:textColor="#94A3B8"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- Change role button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChangeRole"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Role"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:paddingHorizontal="10dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:cornerRadius="8dp"
            app:strokeColor="#432C7A"
            android:textColor="#432C7A" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
