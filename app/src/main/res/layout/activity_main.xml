<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Scrollable Content -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- NAVY HEADER -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1E3A8A"
                android:paddingTop="32dp"
                android:paddingHorizontal="24dp">

                <!-- Greeting Area -->
                <LinearLayout
                    android:id="@+id/llGreeting"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/cvAvatar"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Good morning ☀️"
                        android:textColor="#94A3B8"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hi, User!"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <!-- Circular Avatar -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvAvatar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="#26FFFFFF"
                    app:strokeWidth="1dp"
                    app:strokeColor="#26FFFFFF"
                    app:cardElevation="0dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="@id/llGreeting">
                    <TextView
                        android:id="@+id/tvAvatarInitials"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="Me"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Wallet Pill Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardWalletPill"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    app:cardBackgroundColor="#1FFFFFFF"
                    app:cardCornerRadius="16dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#33FFFFFF"
                    app:cardElevation="0dp"
                    app:layout_constraintTop_toBottomOf="@id/llGreeting"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginBottom="8dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvWalletLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Wallet Balance"
                            android:textColor="#94A3B8"
                            android:textSize="10sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/tvWalletBalance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹0"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvWalletLabel" />

                        <!-- Top Up Button Pill -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnTopUpPill"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="4dp"
                                android:text="Top up →"
                                android:textColor="#1E3A8A"
                                android:textSize="10sp"
                                android:textStyle="bold"/>
                        </com.google.android.material.card.MaterialCardView>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- WAVE DIVIDER -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:scaleType="fitXY"
                android:src="@drawable/bg_wave_header" />

            <!-- MAIN CONTENT SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="32dp">

                <!-- Section 1: Today's Menu -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today's Menu"
                    android:textColor="#0F172A"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTodaysMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="16dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E2E8F0"
                    android:layout_marginBottom="24dp">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Breakfast Row -->
                        <include layout="@layout/row_meal_status"
                                 android:id="@+id/rowBreakfast" />

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" android:layout_marginVertical="12dp"/>

                        <!-- Lunch Row -->
                        <include layout="@layout/row_meal_status"
                                 android:id="@+id/rowLunch" />

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" android:layout_marginVertical="12dp"/>

                        <!-- Dinner Row -->
                        <include layout="@layout/row_meal_status"
                                 android:id="@+id/rowDinner" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Section 2: Confirm Tomorrow -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Confirm Tomorrow"
                    android:textColor="#0F172A"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading date..."
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardConfirmTomorrow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="16dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E2E8F0"
                    android:layout_marginBottom="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/cgMealType"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:singleSelection="true"
                            app:selectionRequired="true"
                            android:layout_marginBottom="12dp">
                            <com.google.android.material.chip.Chip android:id="@+id/chipBreakfast" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Breakfast" style="@style/Widget.MaterialComponents.Chip.Choice"/>
                            <com.google.android.material.chip.Chip android:id="@+id/chipLunch" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lunch" style="@style/Widget.MaterialComponents.Chip.Choice" android:checked="true"/>
                            <com.google.android.material.chip.Chip android:id="@+id/chipDinner" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dinner" style="@style/Widget.MaterialComponents.Chip.Choice"/>
                        </com.google.android.material.chip.ChipGroup>

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/cgStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:singleSelection="true"
                            app:selectionRequired="true"
                            android:layout_marginBottom="12dp">
                            <com.google.android.material.chip.Chip android:id="@+id/chipEat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🟢 Eating" style="@style/Widget.MaterialComponents.Chip.Choice" android:checked="true"/>
                            <com.google.android.material.chip.Chip android:id="@+id/chipSkip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔴 Skipping" style="@style/Widget.MaterialComponents.Chip.Choice"/>
                        </com.google.android.material.chip.ChipGroup>

                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:scrollbars="none"
                            android:layout_marginBottom="16dp">
                            <com.google.android.material.chip.ChipGroup
                                android:id="@+id/cgTimeSlot"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:singleLine="true"
                                app:singleSelection="true">
                                <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="7:00 AM - 8:00 AM" style="@style/Widget.MaterialComponents.Chip.Choice"/>
                                <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="8:00 AM - 9:00 AM" style="@style/Widget.MaterialComponents.Chip.Choice"/>
                                <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12:00 PM - 1:00 PM" style="@style/Widget.MaterialComponents.Chip.Choice"/>
                                <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1:00 PM - 2:00 PM" style="@style/Widget.MaterialComponents.Chip.Choice"/>
                                <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="7:00 PM - 8:00 PM" style="@style/Widget.MaterialComponents.Chip.Choice"/>
                                <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="8:00 PM - 9:00 PM" style="@style/Widget.MaterialComponents.Chip.Choice"/>
                            </com.google.android.material.chip.ChipGroup>
                        </HorizontalScrollView>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSubmitConfirmation"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:text="Save Confirmation"
                            android:textAllCaps="false"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            app:cornerRadius="12dp"
                            android:backgroundTint="#1E3A8A"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Section 3: QR Scan -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnScanQR"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Scan QR Code to Enter"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textColor="#1E3A8A"
                    app:strokeColor="#1E3A8A"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="12dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_marginBottom="24dp"/>

                <!-- Section 4: Rate Meal -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rate Your Meal"
                    android:textColor="#0F172A"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRateMeal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="16dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E2E8F0"
                    android:layout_marginBottom="24dp">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/cgRatingMeal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:singleSelection="true"
                            app:selectionRequired="true"
                            android:layout_marginBottom="12dp">
                            <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Breakfast" style="@style/Widget.MaterialComponents.Chip.Choice" android:checked="true"/>
                            <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lunch" style="@style/Widget.MaterialComponents.Chip.Choice"/>
                            <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dinner" style="@style/Widget.MaterialComponents.Chip.Choice"/>
                        </com.google.android.material.chip.ChipGroup>

                        <RatingBar
                            android:id="@+id/ratingBarMeal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:numStars="5"
                            android:stepSize="1.0"
                            android:rating="0"
                            android:progressTint="#F59E0B"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/btnSubmitRating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap stars to rate"
                            android:textColor="#94A3B8"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Hidden Utility Button (Logout) used by backend currently to test -->
                <Button
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sign Out"
                    android:textColor="#8E8E93"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_marginBottom="8dp"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <View
        android:id="@+id/bottomNavDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E2E8F0"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"/>

    <!-- BOTTOM NAV BAR -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        android:elevation="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:id="@+id/btnNavHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="24dp" android:layout_height="24dp" android:text="🏠" android:textSize="18sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home" android:textColor="#1E3A8A" android:textStyle="bold" android:textSize="10sp"/>
            <View android:layout_width="4dp" android:layout_height="4dp" android:background="@drawable/circle_bg" android:backgroundTint="#1E3A8A" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnNavHistory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="24dp" android:layout_height="24dp" android:text="🧾" android:textSize="18sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="History" android:textColor="#94A3B8" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnNavWallet"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="24dp" android:layout_height="24dp" android:text="💳" android:textSize="18sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Wallet" android:textColor="#94A3B8" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnNavProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="24dp" android:layout_height="24dp" android:text="👤" android:textSize="18sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profile" android:textColor="#94A3B8" android:textSize="10sp"/>
        </LinearLayout>

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>