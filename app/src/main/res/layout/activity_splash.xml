<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

    <!-- Glow ring behind circle -->
    <View
        android:id="@+id/glowRing"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/splash_glow_ring"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.38" />

    <!-- Orange circle background -->
    <View
        android:id="@+id/iconBackground"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:background="@drawable/splash_circle_bg"
        app:layout_constraintBottom_toBottomOf="@id/glowRing"
        app:layout_constraintEnd_toEndOf="@id/glowRing"
        app:layout_constraintStart_toStartOf="@id/glowRing"
        app:layout_constraintTop_toTopOf="@id/glowRing" />

    <!-- Fork & spoon logo icon -->
    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_restaurant_logo"
        android:tint="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="@id/iconBackground"
        app:layout_constraintEnd_toEndOf="@id/iconBackground"
        app:layout_constraintStart_toStartOf="@id/iconBackground"
        app:layout_constraintTop_toTopOf="@id/iconBackground" />

    <!-- "Smart" + "Mess" in a row -->
    <LinearLayout
        android:id="@+id/tvBrandRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/glowRing">

        <TextView
            android:id="@+id/tvSmart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Smart"
            android:textColor="#FF6600"
            android:textSize="34sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="8dp"
            android:layout_height="wrap_content"
            android:text=" " />

        <TextView
            android:id="@+id/tvMess"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mess"
            android:textColor="#00A34F"
            android:textSize="34sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Tagline -->
    <TextView
        android:id="@+id/tvTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your campus canteen, smarter."
        android:textColor="#94A3B8"
        android:textSize="14sp"
        android:letterSpacing="0.01"
        android:layout_marginTop="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvBrandRow" />

    <!-- Loading indicator: three animated dots -->
    <LinearLayout
        android:id="@+id/loadingDots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <View
            android:id="@+id/dot1"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/splash_dot" />

        <View
            android:id="@+id/dot2"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/splash_dot" />

        <View
            android:id="@+id/dot3"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/splash_dot" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
