<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <!-- DEEP PURPLE HEADER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/llHeader"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        app:layout_constraintTop_toTopOf="parent"
        android:background="#432C7A">
        
        <TextView
            android:id="@+id/tvAdminTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin Dashboard"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="48dp"
            android:layout_marginStart="24dp"/>
            
        <TextView
            android:id="@+id/tvAdminSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today"
            android:textColor="#C4B5FD"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tvAdminTitle"
            app:layout_constraintStart_toStartOf="@id/tvAdminTitle"
            android:layout_marginTop="4dp"/>
            
        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_preferences"
            app:tint="#FFFFFF"
            app:layout_constraintTop_toTopOf="@id/tvAdminTitle"
            app:layout_constraintBottom_toBottomOf="@id/tvAdminTitle"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="16dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Wave Clip -->
    <ImageView
        android:id="@+id/ivWave"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:src="@drawable/bg_wave_header_purple"
        android:scaleType="fitXY"
        app:layout_constraintTop_toBottomOf="@id/llHeader"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/llHeader"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipChildren="false">

            <!-- KPI Row (Horizontal Scroll) -->
            <HorizontalScrollView
                android:id="@+id/hsvKpi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:clipToPadding="false"
                android:paddingHorizontal="16dp"
                android:layout_marginTop="-24dp"
                android:layout_marginBottom="24dp">
                
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                    
                    <!-- Bookings Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cvKpiBookings"
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:strokeWidth="0.5dp"
                        app:strokeColor="#E2E8F0"
                        android:layout_marginEnd="12dp"
                        android:layout_marginBottom="8dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="16dp" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tomorrow's Bookings" android:textColor="#64748B" android:textSize="11sp" android:textStyle="bold" android:gravity="center"/>
                            <TextView android:id="@+id/tvKpiBookings" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#432C7A" android:textSize="32sp" android:textStyle="bold" android:layout_marginVertical="8dp"/>
                            
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                                <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/bg_history_badge" android:backgroundTint="#F59E0B" android:layout_marginEnd="4dp"/>
                                <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/bg_history_badge" android:backgroundTint="#0EA5E9" android:layout_marginEnd="4dp"/>
                                <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/bg_history_badge" android:backgroundTint="#432C7A"/>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Avg Rating Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cvKpiRating"
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:strokeWidth="0.5dp"
                        app:strokeColor="#E2E8F0"
                        android:layout_marginEnd="12dp"
                        android:layout_marginBottom="8dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="16dp" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Avg Rating Today" android:textColor="#64748B" android:textSize="11sp" android:textStyle="bold" android:gravity="center"/>
                            <TextView android:id="@+id/tvKpiRating" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0" android:textColor="#F59E0B" android:textSize="32sp" android:textStyle="bold" android:layout_marginVertical="8dp"/>
                            
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="★ ★ ★ ★" android:textColor="#F59E0B" android:textSize="10sp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Waste Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cvKpiWaste"
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:strokeWidth="0.5dp"
                        app:strokeColor="#E2E8F0"
                        android:layout_marginBottom="8dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="16dp" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Waste Today" android:textColor="#64748B" android:textSize="11sp" android:textStyle="bold" android:gravity="center"/>
                            <TextView android:id="@+id/tvKpiWaste" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0kg" android:textColor="#0F172A" android:textSize="32sp" android:textStyle="bold" android:layout_marginVertical="8dp"/>
                            
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                                <TextView android:id="@+id/tvKpiWasteDelta" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="↓ 2kg vs y'day" android:textColor="#16A34A" android:textSize="10sp" android:textStyle="bold"/>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingHorizontal="16dp" android:orientation="vertical">

                <!-- CHART SECTION -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="7-Day Overview"
                    android:textColor="#0F172A"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="12dp"/>
                    
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E2E8F0"
                    app:cardBackgroundColor="#FFFFFF"
                    android:layout_marginBottom="32dp">
                    
                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/wasteBarChart"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp"/>
                </com.google.android.material.card.MaterialCardView>

                <!-- ACTION BUTTONS -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:baselineAligned="false" android:layout_marginBottom="12dp">
                    
                    <!-- Manage Menu -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnManageMenu"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="56dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#EFF6FF"
                        android:layout_marginEnd="6dp"
                        android:foreground="?attr/selectableItemBackground">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🍴" android:textSize="18sp" android:layout_marginEnd="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Manage Menu" android:textColor="#3B82F6" android:textStyle="bold" android:textSize="13sp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- View Feedback -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnViewFeedback"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="56dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#FEF3C7"
                        android:layout_marginStart="6dp"
                        android:foreground="?attr/selectableItemBackground">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💬" android:textSize="18sp" android:layout_marginEnd="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="View Feedback" android:textColor="#F59E0B" android:textStyle="bold" android:textSize="13sp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:baselineAligned="false" android:layout_marginBottom="32dp">
                    
                    <!-- User Management -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnUserManagement"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="56dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#F3E8FF"
                        android:layout_marginEnd="6dp"
                        android:foreground="?attr/selectableItemBackground">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👥" android:textSize="18sp" android:layout_marginEnd="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="User Admin" android:textColor="#9333EA" android:textStyle="bold" android:textSize="13sp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Generate Report -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnGenerateReport"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="56dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#DCFCE7"
                        android:layout_marginStart="6dp"
                        android:foreground="?attr/selectableItemBackground">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📊" android:textSize="18sp" android:layout_marginEnd="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Export Report" android:textColor="#16A34A" android:textStyle="bold" android:textSize="13sp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- LOGOUT -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Log Out"
                    android:textColor="#EF4444"
                    app:cornerRadius="12dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="#EF4444"
                    android:layout_marginBottom="48dp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
